# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Default Taxonomy Overrides (optional)
# Set to the absolute or relative path of your own CSV/Excel/JSON taxonomy file.
# If set and the file exists, it replaces the built-in taxonomy for that LOB.
# Leave blank to use the bundled defaults.
TAXONOMY_EXCESS_AND_SURPLUS_PATH=
TAXONOMY_AUTO_PATH=
